# --- OS Specific Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor/IDE Folders ---
.vscode/
.idea/
*.swp
*.swo

# --- Node/Dependencies (if you ever use npm) ---
node_modules/
package-lock.json

# --- Local Assets/Large Files ---
# 忽略 assets/image/ 資料夾下的所有內容
assets/image/*

# 如果你想保留資料夾但忽略圖片，可以使用以下方式：
# assets/image/*.jpg
# assets/image/*.png
# assets/image/*.jpeg
# assets/image/*.webp

# --- Temp/Log Files ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*